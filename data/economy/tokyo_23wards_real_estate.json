{
  "metadata": {
    "title": "Tokyo 23 Special Wards Real Estate Data",
    "description": "Comprehensive ward-level real estate data for Tokyo's 23 special wards (特別区)",
    "data_year": "2026",
    "compiled_date": "2026-04-15",
    "sources": {
      "land_prices": {
        "name": "tochidai.info (based on MLIT 国土交通省 公示地価)",
        "url": "https://tochidai.info/tokyo/",
        "year": "2026 (令和8年)",
        "note": "Official government land price survey (地価公示) aggregated by ward"
      },
      "population": {
        "name": "Tokyo Metropolitan Government Statistics (東京都の統計)",
        "url": "https://www.toukei.metro.tokyo.lg.jp/juukiy/jy-index.htm",
        "year": "2026 (令和8年1月1日現在)",
        "note": "Based on Basic Resident Register (住民基本台帳)"
      },
      "rents": {
        "name": "SUUMO (リクルート)",
        "url": "https://suumo.jp/chintai/soba/tokyo/",
        "year": "Updated April 2026",
        "note": "Average rents based on active listings. Amounts in 万円 (10,000 yen units)"
      },
      "resale_condo_prices": {
        "name": "LIFULL HOME'S (ホームズ)",
        "url": "https://www.homes.co.jp/mansion/chuko/tokyo/city/price/",
        "year": "April 2026",
        "note": "Average resale condo price for 70m² unit based on 3-month listing data. Amounts in 万円 (10,000 yen units = millions)"
      },
      "area": {
        "name": "Wikipedia / National Land Information (国土地理院)",
        "note": "Official ward area figures in km²"
      }
    },
    "column_definitions": {
      "avg_land_price_yen_m2": "Overall average land price (residential + commercial + industrial) per m² in yen",
      "residential_land_price_yen_m2": "Average residential zone (住宅地) land price per m² in yen",
      "commercial_land_price_yen_m2": "Average commercial zone (商業地) land price per m² in yen",
      "land_price_yoy_change_pct": "Year-over-year change in overall average land price (%)",
      "resale_condo_70m2_million_yen": "Average resale condo price for a 70m² unit in million yen (百万円)",
      "rent_*_man_yen": "Average monthly rent in 万円 (10,000 yen). E.g., 11.0 = ¥110,000/month"
    }
  },
